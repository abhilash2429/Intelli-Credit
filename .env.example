# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/intellicredit
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_DOCUMENTS=document_chunks
QDRANT_COLLECTION_RESEARCH=research_chunks

# LLMs
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HF_FREE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VL_PROVIDER=huggingface
QWEN_VL_API_KEY=
QWEN_VL_BASE_URL=https://router.huggingface.co/v1
QWEN_VL_TIMEOUT_SEC=90
LLM_PROVIDER=cerebras

# Primary LLM provider (Cerebras gpt-oss-120b)
CEREBRAS_API_KEY=your_cerebras_api_key
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Web Research
GROK_API_KEY=your_grok_api_key
SARVAM_API_KEY=optional_legacy_only

# Web Research
SERPER_API_KEY=your_serper_api_key
TAVILY_API_KEY=your_tavily_api_key
MAX_TAVILY_RESULTS_PER_SEARCH=10
MAX_RESEARCH_SOURCES_PER_COMPANY=50
RESEARCH_DEPTH=deep

# Databricks / Delta
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxxxxx.xx.azuredatabricks.net
DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxx
DATABRICKS_CLUSTER_ID=xxxx-xxxxxx-xxxxxxxx
DATABRICKS_CATALOG=intelli_credit
DATABRICKS_SCHEMA=credit_appraisal
SPARK_LOCAL_MODE=true
DELTA_LAKE_PATH=./delta_lake

# App
SECRET_KEY=your_secret_key
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
RESEARCH_MODE=live
CACHE_DIR=./cache
CAM_OUTPUT_DIR=./outputs/cam
REPORT_BANK_NAME=Intelli-Credit Demo Bank
BASE_INTEREST_RATE=8.5
FRONTEND_URL=http://localhost:3000
